# Публичный URL сайта (для canonical, Open Graph и sitemap)
VITE_SITE_URL=https://example.com

# Форма обратной связи — достаточно одного варианта:

# Web3Forms (бесплатно): https://web3forms.com → получите access key
VITE_WEB3FORMS_ACCESS_KEY=

# Formspree (альтернатива): https://formspree.io → ID формы из URL
# VITE_FORMSPREE_FORM_ID=
